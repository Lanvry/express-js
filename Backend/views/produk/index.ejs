<%- include('../partials/_head') %>
    <div class="main-container">
      <div class="header-section">
        <h1>
          <a href="/" style="position: relative; top: 4px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
           Produk
          </h1>
        <a href="/produk/create" class="btn btn-create">
          <span class="icon">+</span> Tambah Produk
        </a>
      </div>
      <div class="table-card">
        <table id="myTable" class="display">
          <thead>
            <tr>
              <th>No</th>
              <th>Nama Produk</th>
              <th>Harga</th>
              <th>Stok</th>
              <th>Kategori</th>
              <th>Gambar</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% data.forEach(function(produk, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= produk.nama_produk %></td>
              <td><%= produk.harga %></td>
              <td><%= produk.stok %></td>
              <td><%= produk.id_kategori %></td>
              <td>
                <% if (produk.gambar) { %>
                  <img src="/images/<%= produk.gambar %>" alt="<%= produk.nama_produk %>" style="max-height: 60px; border-radius: 4px;">
                <% } else { %>
                  <span>-</span>
                <% } %>
              </td>
              <td>
                <a href="/produk/edit/<%= produk.id_produk %>" class="btn-action edit">Edit</a>
                <a href="/produk/delete/<%= produk.id_produk %>" class="btn-action delete" onclick="return confirm('Yakin hapus?')">Delete</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
<%- include('../partials/_foot') %>