<% if (typeof messages !== 'undefined' && messages.success) { %>
    <div class="alert alert-success" style="padding: 1rem; margin-bottom: 1rem; background: #dcfce7; color: #166534; border-radius: 8px; border: 1px solid #bbf7d0;">
      <%= messages.success %>
    </div>
<% } %>
<% if (typeof messages !== 'undefined' && messages.error) { %>
    <div class="alert alert-error" style="padding: 1rem; margin-bottom: 1rem; background: #fee2e2; color: #991b1b; border-radius: 8px; border: 1px solid #fecaca;">
      <%= messages.error %>
    </div>
<% } %>
