<%- include('../partials/_head') %>
    <div class="main-container">
      <div class="header-section">
        <h1>
          <a href="/" style="position: relative; top: 4px; color: black; text-decoration: none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
           Pengaturan Akun (<%= user.email %>)
        </h1>
      </div>

      <div class="form-card">
        <% if (messages && messages.error) { %>
          <div style="background: #fef2f2; color: #b91c1c; border: 1px solid #fca5a5; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
              <%= messages.error %>
          </div>
        <% } %>
        <% if (messages && messages.success) { %>
          <div style="background: #f0fdf4; color: #15803d; border: 1px solid #86efac; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
              <%= messages.success %>
          </div>
        <% } %>

        <form action="/users/change-password" method="POST">
          <div class="form-group">
            <label class="form-label required-field" for="old_password">Password Lama</label>
            <input type="password" id="old_password" name="old_password" class="form-input" required placeholder="Masukkan password lama...">
          </div>
          
          <div class="form-group">
            <label class="form-label required-field" for="new_password">Password Baru</label>
            <input type="password" id="new_password" name="new_password" class="form-input" required placeholder="Masukkan password baru...">
          </div>
          
          <div class="form-group">
            <label class="form-label required-field" for="confirm_password">Konfirmasi Password Baru</label>
            <input type="password" id="confirm_password" name="confirm_password" class="form-input" required placeholder="Konfirmasi password baru...">
          </div>
          
          <div class="form-actions">
            <button type="submit" class="btn-save">Simpan Perubahan</button>
            <a href="/" class="btn-cancel">Batal</a>
          </div>
        </form>
      </div>
    </div>
<%- include('../partials/_foot') %>