<%- include('../partials/_head') %>
    <div class="main-container">
      <div class="header-section">
        <h1>
          <a href="/" style="position: relative; top: 4px; color: black; text-decoration: none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
           Profil Pengguna
        </h1>
      </div>

      <div class="form-card">
        <% if (messages && messages.success) { %>
          <div style="background: #f0fdf4; color: #15803d; border: 1px solid #86efac; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
              <%= messages.success %>
          </div>
        <% } %>

        <div style="margin-bottom: 24px; text-align: center;">
          <div style="width: 100px; height: 100px; background: #e2e8f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px auto; font-size: 32px; color: #64748b;">
            👤
          </div>
          <h2 style="margin: 0 0 8px 0; color: #0f172a;"><%= user.email.split('@')[0] %></h2>
          <p style="margin: 0; color: #64748b;"><%= user.email %></p>
        </div>

        <hr style="border: none; border-top: 1px solid #e2e8f0; margin-bottom: 24px;">

        <div class="form-actions" style="justify-content: center; gap: 16px;">
          <a href="/users/changepassword" class="btn-save" style="text-decoration: none; display: inline-block;">Ubah Password</a>
        </div>
      </div>
    </div>
<%- include('../partials/_foot') %>