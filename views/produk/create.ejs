<%- include('../partials/_head') %>
    <div class="form-card">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <h1>Tambah Produk</h1>
        <a href="/produk" class="delete" style="text-decoration: none">Kembali</a>
      </div>
      <form action="/produk/store" method="POST">
        <div class="form-group">
          <label for="nama_produk" class="form-label required-field">Nama Produk</label>
          <input type="text" id="nama_produk" name="nama_produk" class="form-input" placeholder="Masukkan nama produk..." required />
        </div>
        <div class="form-group">
          <label for="harga" class="form-label required-field">Harga</label>
          <input type="number" id="harga" name="harga" class="form-input" placeholder="Masukkan harga..." required />
        </div>
        <div class="form-group">
          <label for="stok" class="form-label required-field">Stok</label>
          <input type="number" id="stok" name="stok" class="form-input" placeholder="Masukkan stok..." required />
        </div>
        <div class="form-group">
          <label for="id_kategori" class="form-label required-field">Kategori</label>
          <select id="id_kategori" name="id_kategori" class="form-input" required>
            <option value="">-- Pilih Kategori --</option>
            <% kategori.forEach(function(item) { %>
              <option value="<%= item.id_kategori %>"><%= item.nama_kategori %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-save">Simpan</button>
          <a href="/produk" class="btn-cancel">Batal</a>
        </div>
      </form>
    </div>
<%- include('../partials/_foot') %>